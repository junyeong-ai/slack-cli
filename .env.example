# Slack CLI - Environment Variables Template
# Copy this file to .env and fill in your actual values

# ============================================
# Required Configuration
# ============================================

# Slack User Token (recommended for Real-time Search and user-visible private data)
# Get this from: https://api.slack.com/apps → Your App → OAuth & Permissions
# Search scopes: search:read.public, search:read.private, search:read.im,
# search:read.mpim, search:read.files, search:read.users
# Format: xoxp-...
SLACK_USER_TOKEN=xoxp-your-user-token-here

# ============================================
# Optional Configuration
# ============================================

# Slack Bot Token (optional, from OAuth & Permissions)
# Format: xoxb-...
# SLACK_BOT_TOKEN=xoxb-your-bot-token-here

# Database and Cache Location
# Default: ~/.config/slack-cli/cache
# DATA_PATH=~/.config/slack-cli/cache

# Logging Level
# Options: error | warn | info | debug | trace
# Default: warn
# LOG_LEVEL=warn

# Module-Specific Logging (for debugging)
# Examples:
#   - All modules debug: RUST_LOG=debug
#   - Specific module: RUST_LOG=slack_cli::cache=debug
#   - Multiple modules: RUST_LOG=slack_cli::cache=debug,slack_cli::slack=info
# RUST_LOG=slack_cli=debug
